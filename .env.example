# =============================================================================
# MoveBuddy — Environment Variables
#
# WARNING: NEVER commit the .env file to version control.
# Copy this file to .env and fill in your values.
# All values shown here are PLACEHOLDERS — replace before starting.
# =============================================================================
# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ── Database (PostgreSQL via Prisma) ────────────────────────────────────────
# Required. The app will not start without a working database connection.
# URL-encode special characters in the password (e.g. @ → %40).
DATABASE_URL="postgresql://user:password@localhost:5432/movebuddy"

# ── JWT Auth (REQUIRED in production — server refuses to boot without these) ─
# Generate with: openssl rand -hex 48
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── OTP / Phone Verification ────────────────────────────────────────────────
# Production: set ALLOW_DEV_OTP=false or unset. Set to true ONLY in local dev.
# The server hard-blocks startup if NODE_ENV=production AND ALLOW_DEV_OTP=true.
ALLOW_DEV_OTP="false"

# Firebase Admin SDK (for real phone OTP verification)
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""

# Firebase Web SDK config (exposed to frontend — safe to commit)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ── Google Maps (Required for route distance + geocoding) ───────────────────
GOOGLE_MAPS_API_KEY=""
VITE_GOOGLE_MAPS_API_KEY=""

# ── Payments (Razorpay) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Set to "true" to bypass Razorpay checkout and auto-complete payments (dev only)
PAYMENTS_DEV_BYPASS="true"

# ── Media (Cloudinary) ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@movebuddy.com"

# ── AI / Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=""

# ── Monitoring (Sentry) ─────────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ── Redis (Required for distributed locking + rate limiting in multi-replica) ─
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ── Rate Limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Truecaller (mobile one-tap verification — stubbed until mobile app ships) ─
TRUECALLER_APP_KEY=""

# ── MSG91 (SMS provider — fallback OTP delivery) ────────────────────────────
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="MVBUDY"
MSG91_TEMPLATE_ID=""

# ── PhonePe (Alternative payment provider) ──────────────────────────────────
PHONEPE_MERCHANT_ID=""
PHONEPE_MERCHANT_USER_ID=""
PHONEPE_SALT_KEY=""
PHONEPE_SALT_INDEX=1
PHONEPE_ENV="sandbox"
