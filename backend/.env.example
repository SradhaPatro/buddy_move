# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/movebuddy

# ── Auth / JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ── Google Maps ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── OTP / SMS (MSG91) ────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=MVBUDY
MSG91_TEMPLATE_ID=

# ── Payments (Razorpay) ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Payments (PhonePe) ───────────────────────────────────────────
PHONEPE_MERCHANT_ID=
PHONEPE_MERCHANT_USER_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=sandbox

# ── Firebase FCM ─────────────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@movebuddy.com

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Sentry (Monitoring) ──────────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
