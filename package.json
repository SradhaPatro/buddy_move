{
  "name": "move-buddy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx backend/server.ts\" \"vite --config frontend/vite.config.ts\"",
    "dev:backend": "tsx backend/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts && esbuild backend/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cleanup:data": "tsx scripts/cleanup-placeholder-data.ts",
    "backfill:payments": "tsx scripts/backfill-payments.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@number-flow/react": "^0.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.5.0",
    "@prisma/config": "^7.8.0",
    "@radix-ui/react-toggle": "^1.1.11",
    "@sentry/integrations": "^7.114.0",
    "@sentry/node": "^10.62.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "esbuild": "^0.25.0",
    "jsdom": "^21.1.2",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
